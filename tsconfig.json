{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "$src/*": ["./src/*"],
      "$env": ["./src/env.ts"],
      "$db": ["./src/db/*"]
    }
  }
}
